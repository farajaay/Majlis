# GitHub OAuth App (github.com/settings/developers -> OAuth Apps)
# Authorization callback URL: https://<your-vercel-domain>/api/auth/callback/github
GITHUB_ID=
GITHUB_SECRET=

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=  # generate with: openssl rand -base64 32

# Who may enter the council — comma-separated GitHub logins, case-insensitive.
# Checked for BOTH browser sign-in and agent Bearer-token requests.
ALLOWED_GITHUB_LOGINS=ahmad,some-other-login

# MongoDB Atlas, via Vercel's marketplace integration (Storage tab -> connect
# a Mongo store to the project injects this automatically). The app always
# uses its own `majlis` database inside whatever cluster this points at, so
# it's safe to share a cluster with other projects.
MONGODB_URI=

# Vercel Blob (Storage tab -> Blob -> Connect to project injects this automatically)
BLOB_READ_WRITE_TOKEN=
